{
  "name": "ngx-giscus-workspace",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve demo",
    "build:lib": "ng build ngx-giscus",
    "build:demo": "ng build demo",
    "build": "npm run build:lib && npm run build:demo",
